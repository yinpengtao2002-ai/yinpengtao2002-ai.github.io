# 聊天 API 配置（任何 OpenAI 兼容接口均可）
# 示例使用小弛 API，也支持其他 OpenAI 兼容服务
CHAT_API_URL=https://llm.xiaochisaas.com/v1/chat/completions
CHAT_API_KEY=sk-your-key-here
CHAT_MODEL=claude-opus-4-6-thinking
CHAT_MODEL_FALLBACK=gpt-5.3-codex

# Notion 集成（可选，留空则只用本地 markdown）
# 从 https://www.notion.so/profile/integrations 创建 Internal integration 获取 Token
# Database ID 从数据库 URL 中提取（32 位字符）
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# 设为 "true" 启用 GitHub Pages 静态导出（禁用 API 路由）
STATIC_EXPORT=
