# Copy this file to .env.local for local development.
# Never put real secrets in this template.

# Notion content sync
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# AI providers
# Primary provider runs first; DeepSeek is the fallback.
AI_PROVIDER_ORDER=primary,deepseek
AI_PRIMARY_API_KEY=
AI_PRIMARY_API_URL=https://api.dstopology.com
AI_PRIMARY_MODEL=gpt-5.5
AI_PRIMARY_TTS_MODEL=tts-1-hd
AI_PRIMARY_TTS_VOICE=nova

# Optional: set these only when DeepSeek uses a separate direct key.
# Otherwise fallback reuses the primary NewAPI connection with model deepseek-v4-pro.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Shared production rate limiting for public AI and access-code routes.
# Production fails closed when either Upstash value is missing.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Private tools only. The human-entered access code and token-signing secret
# must be different values; generate PRIVATE_TOOL_TOKEN_SECRET as a high-entropy secret.
PRIVATE_TOOL_ACCESS_KEY=
PRIVATE_TOOL_TOKEN_SECRET=
