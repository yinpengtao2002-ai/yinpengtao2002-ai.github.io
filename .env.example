# Copy this file to .env.local for local development.
# Never put real secrets in this template.

# Notion content sync
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# Site chat assistant
# Default provider is DeepSeek only. Set CHAT_ENABLE_PROVIDER_FALLBACKS=true only if you intentionally want third-party fallback providers.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
CHAT_ENABLE_PROVIDER_FALLBACKS=false
CHAT_API_KEY=
CHAT_API_URL=https://api.884819.xyz/v1/chat/completions

# Finance AI assistant internal beta gate
FINANCE_AI_ACCESS_KEY=

# Static export
# Usually prefer: npm run build:static
# STATIC_EXPORT=true
