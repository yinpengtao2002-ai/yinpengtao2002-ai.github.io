# Copy this file to .env.local for local development.
# Never put real secrets in this template.

# Notion content sync
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# AI providers
# Primary provider runs first; DeepSeek is the fallback.
AI_PRIMARY_API_KEY=
AI_PRIMARY_API_URL=https://api.dstopology.com
AI_PRIMARY_MODEL=gpt-5.5
AI_PRIMARY_TTS_MODEL=tts-1-hd
AI_PRIMARY_TTS_VOICE=nova

# Optional: set these only when DeepSeek uses a separate direct key.
# Otherwise fallback reuses the primary NewAPI connection with model deepseek-v4-pro.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Finance AI assistant internal beta gate
FINANCE_AI_ACCESS_KEY=

# Static export
# Usually prefer: npm run build:static
# STATIC_EXPORT=true
