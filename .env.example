# Copy this file to .env.local for local development.
# Never put real secrets in this template.

# Notion content sync
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# Site chat assistant
# Default provider is DeepSeek only.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Finance AI assistant internal beta gate
FINANCE_AI_ACCESS_KEY=

# Static export
# Usually prefer: npm run build:static
# STATIC_EXPORT=true
