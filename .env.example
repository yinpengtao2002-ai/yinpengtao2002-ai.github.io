# Copy this file to .env.local for local development.
# Never put real secrets in this template.

# Notion content sync
NOTION_TOKEN=
NOTION_AI_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=

# Site chat assistant
# Use an OpenAI-compatible API endpoint.
CHAT_API_KEY=
CHAT_API_URL=
CHAT_MODEL=
CHAT_MODEL_FALLBACK=

# Static export
# Usually prefer: npm run build:static
# STATIC_EXPORT=true
